        <mxCell id="0IsRI0MfsEx4Ne2D6Ogz-40" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontColor=#000000;align=left;verticalAlign=top;" value="&lt;div style=&quot;text-align: left; padding: 5px;&quot;&gt;&lt;b style=&quot;font-size: 15px; color: #cc0000;&quot;&gt;⚠️ 小任务调度瓶颈 (空泡现象)&lt;/b&gt;&lt;hr style=&quot;border-color: #ffcccc;&quot;&gt;&lt;ul style=&quot;margin-top:5px; padding-left:20px;&quot;&gt;&lt;li&gt;&lt;b&gt;单次任务执行:&lt;/b&gt; 10 μs&lt;/li&gt;&lt;li&gt;&lt;b&gt;Pipe 全量 Queue 切换:&lt;/b&gt; 40 μs&lt;/li&gt;&lt;/ul&gt;&lt;b&gt;调度机制导致的后果：&lt;/b&gt;&lt;br&gt;由于切换硬件队列的上下文开销 (40us) 远大于单个微小任务的计算耗时 (10us)，在密集型小任务下发时，&lt;b style=&quot;color:#cc0000;&quot;&gt;计算单元 (CU) 大量时间处于闲置等待状态&lt;/b&gt;，从而在流水线上产生明显的&lt;b&gt;“执行空泡” (Idle Bubbles)&lt;/b&gt;，极大降低了 GPU 硬件的综合利用率。&lt;/div&gt;" vertex="1">
          <mxGeometry height="230" width="230" x="4000" y="1820" as="geometry" />
        </mxCell>
